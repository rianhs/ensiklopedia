---
layout: none
---
{% assign all_pages = site.pages | concat: site.documents %}
{% assign first = true %}
[
{% for p in all_pages %}{% if p.title and p.title != "" and p.url != "/search.json" %}{% unless first %},{% endunless %}{% assign first = false %}
  {"title":{{ p.title | jsonify }},"url":"{{ site.baseurl }}{{ p.url }}"{% if p.description %},"description":{{ p.description | jsonify }}{% endif %}}
{% endif %}{% endfor %}
]
